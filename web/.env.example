# USDA FoodData Central API key
# Get a free key at: https://fdc.nal.usda.gov/api-guide.html
# Copy this file to .env.local and paste your key after the =
VITE_USDA_API_KEY=your_key_here

# FastAPI backend base URL — enables the AI plan-explainer on the Plan page.
# Set to http://localhost:8000 for local development.
# Leave unset on Vercel (frontend-only deploy) to show a coming-soon state instead.
VITE_BACKEND_URL=http://localhost:8000
